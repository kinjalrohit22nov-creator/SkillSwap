{
  "$schema": "https://turbo.build/json-schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "MONGODB_URI",
    "REDIS_URL",
    "JWT_SECRET"
  ],
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["build/**", "dist/**", ".next/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["db:migrate"]
    }
  }
}
