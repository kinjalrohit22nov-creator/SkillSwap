# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/skillswap
MONGODB_URI=mongodb://localhost:27017/skillswap
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback

# ── AI ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_ENV=

# ── Payments ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Storage ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=skillswap-uploads

# ── Email ─────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@skillswap.app

# ── Service Ports ─────────────────────────────
GATEWAY_PORT=8080
USER_SERVICE_PORT=3001
MATCH_SERVICE_PORT=3002
SESSION_SERVICE_PORT=3003
TOKEN_SERVICE_PORT=3004
AI_SERVICE_PORT=3005

# ── App ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SOCKET_URL=http://localhost:8080
NODE_ENV=development
